{
  "name": "task-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cloudflare": "cross-env DEPLOY_TARGET=cloudflare-pages next build",
    "start": "next start",
    "package:portable": "powershell -ExecutionPolicy Bypass -File scripts/package-portable.ps1",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "audit": "npm audit --audit-level=high",
    "supabase:seed-admin": "node --env-file=.env.local scripts/seed-supabase-admin.mjs",
    "supabase:migrate-data": "node --env-file=.env.local scripts/migrate-sqlite-to-supabase.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/material-nextjs": "^9.0.1",
    "@mui/x-data-grid": "^9.1.0",
    "@supabase/supabase-js": "^2.110.3",
    "better-sqlite3": "^12.10.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.12",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-quill-new": "^3.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "quill": "2.0.2",
    "postcss": "8.5.10"
  }
}
